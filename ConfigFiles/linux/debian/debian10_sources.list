# 默认注释了源码镜像以提高 apt update 速度，如有需要可自行取消注释
deb https://mirror.nju.edu.cn/debian/ buster main non-free contrib
# deb-src https://mirror.nju.edu.cn/debian/ buster main non-free contrib

deb https://mirror.nju.edu.cn/debian/ buster-updates main non-free contrib
# deb-src https://mirror.nju.edu.cn/debian/ buster-updates main non-free contrib

deb https://mirror.nju.edu.cn/debian/ buster-backports main contrib non-free
# deb-src https://mirror.nju.edu.cn/debian/ buster-backports main contrib non-free

# 以下安全更新软件源包含了官方源与镜像站配置，如有需要可自行修改注释切换
deb https://mirror.nju.edu.cn/debian-security buster-security main contrib non-free
# deb-src https://mirror.nju.edu.cn/debian-security buster-security main contrib non-free

# deb https://security.debian.org/debian-security buster-security main contrib non-free
# # deb-src https://security.debian.org/debian-security buster-security main contrib non-free

